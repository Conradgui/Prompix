# Prompix environment template
# Do NOT commit real keys.

# Next Web runtime policy
# local | public-live | public-demo
NEXT_PUBLIC_RUNTIME_POLICY=local

# MiniMax managed mode
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_BASE_URL=https://api.minimaxi.com/v1/chat/completions

# Optional Upstash rate limit
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
