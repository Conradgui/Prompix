# Runtime policy
# local: 本地开发（平台直连 + 自定义 Key）
# public-live: 公网可用（平台直连默认 + 自定义 Key 可选）
# public-demo: 公网演示（锁定平台直连，自定义 Key 禁用）
NEXT_PUBLIC_RUNTIME_POLICY=local

# Managed MiniMax (required for demo/platform-connected mode)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_BASE_URL=https://api.minimaxi.com/v1/chat/completions

# Optional rate limit (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Developer mode password (required for public runtime when entering /dev-lab)
PROMPIX_DEV_MODE_PASSWORD=
