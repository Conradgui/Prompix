# Prompix environment template
# Do NOT commit real keys.

# Next Web runtime policy
# local | public-live | public-demo
NEXT_PUBLIC_RUNTIME_POLICY=local

# Managed Gemini (required for demo/platform-connected mode)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional Upstash rate limit
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
